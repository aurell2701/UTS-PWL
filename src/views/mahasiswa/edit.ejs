<div class="bg-white p-6 rounded-2xl shadow max-w-lg">
  <h2 class="text-xl font-bold mb-4">Edit Mahasiswa</h2>
  
  <form onsubmit="return validateForm()" action="/mahasiswa/update/<%= mhs.id %>" method="POST">
    <input 
      name="nama" 
      value="<%= mhs.nama %>" 
      class="w-full mb-3 p-2 border rounded focus:ring-2 focus:ring-yellow-500 outline-none" 
    />
    
    <input 
      name="nim" 
      value="<%= mhs.nim %>" 
      class="w-full mb-3 p-2 border rounded focus:ring-2 focus:ring-yellow-500 outline-none" 
    />
    
    <div class="flex gap-3 mt-2">
      <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded transition">
        Update
      </button>
      
      <a href="/mahasiswa" class="bg-gray-400 hover:bg-gray-500 text-white px-4 py-2 rounded transition text-center">
        Kembali
      </a>
    </div>
  </form>
</div>

<script>
  function validateForm() {
    const nama = document.querySelector('input[name="nama"]').value;
    const nim = document.querySelector('input[name="nim"]').value;

    if (!nama.trim() || !nim.trim()) {
      Swal.fire({
        icon: 'error',
        title: 'Oops...',
        text: 'Nama dan NIM wajib diisi!',
        confirmButtonColor: '#EAB308'
      });
      return false;
    }
    return true;
  }
</script>